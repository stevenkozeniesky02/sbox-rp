    ShopSection[] BuildShopSections()
    {
        return
        [
            new ShopSection(
                "Printers",
                "Buy money printers to generate cash over time.",
                PrinterDefinitions
                    .Select( x => new ShopItem( x.Title, x.Price, x.Description, x.ResourcePath ) )
                    .ToArray()
            ),
            new ShopSection(
                "Weapons",
                "Sandbox weapons available for individual purchase.",
                WeaponShopCatalog.GetAll()
                    .Select( x => new ShopItem( x.Title, x.Price, x.Description, weaponPrefabPath: x.PrefabPath ) )
                    .ToArray()
            ),
            new ShopSection(
                "Shipments",
                "Buy crate shipments that dispense 10 pickup-ready weapons.",
                WeaponShipmentCatalog.GetAll()
                    .Select( x => new ShopItem(
                        x.Title,
                        x.Price,
                        x.Description,
                        shipmentWeaponPrefabPath: x.WeaponPrefabPath,
                        shipmentCount: x.WeaponsPerShipment ) )
                    .ToArray()
            ),
            new ShopSection(
                "Ammo",
                "Buy ammo packs for shared weapon reserves.",
                AmmoShopCatalog.GetAll()
                    .Select( x => new ShopItem( x.Title, x.Price, x.Description, ammoPrefabPath: x.PrefabPath ) )
                    .ToArray()
            ),
            new ShopSection(
                "Miscellaneous",
                "Job utility items and roleplay equipment.",
                MiscShopCatalog.GetAll()
                    .Select( x => new ShopItem( x.Title, x.Price, x.Description, miscPrefabPath: x.PrefabPath ) )
                    .ToArray()
            )
        ];
    }

    IReadOnlyList<JobDefinition> BuildJobDefinitions()
    {
        var jobs = JobDefinition.GetAll().ToList();

        var thief = JobDefinition.Get( Player.ThiefJobDefinitionPath );
        if ( thief is not null && !jobs.Any( x => string.Equals( x.ResourcePath, thief.ResourcePath, StringComparison.OrdinalIgnoreCase ) ) )
        {
            jobs.Add( thief );
            jobs = jobs
                .OrderBy( x => x.Order )
                .ThenBy( x => x.Category )
                .ThenBy( x => x.Title )
                .ToList();
        }

        return jobs;
    }

    IEnumerable<PlayerData> GetPlayers()
    {
        return Scene.GetAll<PlayerData>()
            .OrderByDescending( x => x.Kills )
            .ThenBy( x => x.DisplayName );
    }

    IEnumerable<PlayerData> GetOnlineStaff()
    {
        return GetPlayers().Where( x => GetPlayerAdminRole( x ) != AdminRole.None );
    }

    IEnumerable<KeyValuePair<SteamId, AdminSystem.Entry>> GetSavedStaffEntries()
    {
        if ( !Networking.IsHost )
            return Enumerable.Empty<KeyValuePair<SteamId, AdminSystem.Entry>>();

        return AdminSystem.Current?.GetEntries()
            .OrderByDescending( x => x.Value.Role )
            .ThenBy( x => x.Value.DisplayName )
            ?? Enumerable.Empty<KeyValuePair<SteamId, AdminSystem.Entry>>();
    }

    AdminRole GetPlayerAdminRole( PlayerData entry )
    {
        if ( entry?.Connection?.IsHost == true )
            return AdminRole.SuperAdmin;

        return Player.For( entry?.PlayerId ?? Guid.Empty )?.AdminRole ?? AdminRole.None;
    }

    string GetRoleLabel( AdminRole role )
    {
        return role switch
        {
            AdminRole.Admin => "Admin",
            AdminRole.SuperAdmin => "SuperAdmin",
            _ => "Player"
        };
    }

    string GetRoleClass( AdminRole role )
    {
        return role switch
        {
            AdminRole.Admin => "admin",
            AdminRole.SuperAdmin => "superadmin",
            _ => "none"
        };
    }

    string FormatCurrency( int amount ) => $"${amount:n0}";

    bool TryGetDropMoneyAmount( out int amount )
    {
        return int.TryParse( _dropMoneyValue, out amount ) && amount > 0;
    }

    bool TryGetRoleplayName( out string roleplayName )
    {
        roleplayName = string.Join( " ", (_roleplayNameValue ?? string.Empty).Trim().Split( ' ', StringSplitOptions.RemoveEmptyEntries ) );
        return !string.IsNullOrWhiteSpace( roleplayName );
    }

    bool TryGetCityLawText( out string lawText )
    {
        lawText = string.Join( " ", (_cityLawValue ?? string.Empty).Trim().Split( ' ', StringSplitOptions.RemoveEmptyEntries ) );
        if ( lawText.Length > CityLawManager.MaxLawLength )
        {
            lawText = lawText[..CityLawManager.MaxLawLength].Trim();
        }

        return !string.IsNullOrWhiteSpace( lawText );
    }

    bool TryGetAdminSteamId( out long steamId )
    {
        steamId = 0;
        return ulong.TryParse( _adminSteamIdValue, out var parsed ) && parsed > 0 && (steamId = (long)parsed) > 0;
    }

    void DropMoney()
    {
        if ( !TryGetDropMoneyAmount( out var amount ) )
            return;

        LocalPlayer?.RequestDropMoney( amount );
        _dropMoneyValue = "";
        DropMoneyEntry?.Blur();
    }

    void SubmitRoleplayName()
    {
        if ( !TryGetRoleplayName( out var roleplayName ) )
            return;

        LocalPlayer?.RequestSetRoleplayName( roleplayName );
        _roleplayNameValue = "";
        RoleplayNameEntry?.Blur();
    }

    void SubmitCityLaw()
    {
        if ( !CanManageCityLaws || !TryGetCityLawText( out var lawText ) )
            return;

        CityLawManager.Current?.RequestAddLaw( lawText );
        _cityLawValue = "";
        LawEntry?.Blur();
    }

    void RemoveCityLaw( int index )
    {
        if ( !CanManageCityLaws )
            return;

        CityLawManager.Current?.RequestRemoveLaw( index );
    }

    void SubmitAdminRole( AdminRole role )
    {
        if ( !TryGetAdminSteamId( out var steamId ) )
            return;

        LocalPlayer?.RequestSetAdminRole( steamId, role );
        _adminSteamIdValue = "";
        AdminSteamIdEntry?.Blur();
    }

    void SetOpen( bool open )
    {
        if ( _isOpen == open )
            return;

        _isOpen = open;

        if ( !open )
        {
            DropMoneyEntry?.Blur();
            RoleplayNameEntry?.Blur();
            LawEntry?.Blur();
            AdminSteamIdEntry?.Blur();
        }
    }

    void CloseFromDropEntry()
    {
        SetOpen( false );
    }

    void CloseFromRoleplayNameEntry()
    {
        SetOpen( false );
    }

    void CloseFromLawEntry()
    {
        SetOpen( false );
    }

    void CloseFromAdminEntry()
    {
        SetOpen( false );
    }

    public static Panel GetMenuOverlay()
    {
        return _currentMenuOverlay.IsValid() ? _currentMenuOverlay : null;
    }

    async void FetchMap()
    {
        var ident = Networking.MapName;

        var pkg = await Package.FetchAsync( ident, false );
        if ( pkg is not null )
        {
            _mapTitle = pkg.Title;
        }
    }

    protected override void OnUpdate()
    {
        if ( MenuOverlay.IsValid() )
        {
            _currentMenuOverlay = MenuOverlay;
        }

        Panel.AcceptsFocus = false;
        var dropMoneyHasFocus = DropMoneyEntry?.HasFocus ?? false;
        var roleplayNameHasFocus = RoleplayNameEntry?.HasFocus ?? false;
        var lawEntryHasFocus = LawEntry?.HasFocus ?? false;
        var adminSteamIdHasFocus = AdminSteamIdEntry?.HasFocus ?? false;

        var host = Game.ActiveScene.Get<SpawnMenuHost>();
        if ( host?.Panel?.HasClass( "open" ) ?? false )
        {
            SetOpen( false );
            Input.Clear( "Score" );
        }

        if ( !CanAccessAdministration && _currentPage == ScoreboardPage.Administration )
        {
            _currentPage = ScoreboardPage.Players;
        }

        if ( (Input.Pressed( "Score" ) || Input.Keyboard.Pressed( "Tab" )) && !dropMoneyHasFocus && !roleplayNameHasFocus && !lawEntryHasFocus && !adminSteamIdHasFocus )
        {
            SetOpen( !_isOpen );
        }

        SetClass( "visible", _isOpen );
    }

    protected override int BuildHash()
    {
        var hash = new System.HashCode();
        hash.Add( _currentPage );
        hash.Add( CanAccessAdministration );
        hash.Add( CanManageAdminRoles );

        foreach ( var item in NavigationItems )
            hash.Add( item.Title );

        switch ( _currentPage )
        {
            case ScoreboardPage.Dashboard:
                hash.Add( LocalPlayerName );
                hash.Add( LocalPlayerJob );
                hash.Add( LocalPlayerMoney );
                hash.Add( LocalPlayerSalary );
                hash.Add( SessionType );
                hash.Add( _dropMoneyValue );
                hash.Add( _roleplayNameValue );
                hash.Add( _cityLawValue );
                hash.Add( CanManageCityLaws );
                hash.Add( CityLawManager.Current?.Revision ?? 0 );

                foreach ( var law in CityLaws )
                    hash.Add( law );
                break;

            case ScoreboardPage.Players:
                hash.Add( PlayerCount );

                foreach ( var player in GetPlayers() )
                {
                    hash.Add( player.PlayerId );
                    hash.Add( player.DisplayName );
                    hash.Add( player.JobDefinitionPath );
                    hash.Add( player.JobTitle );
                    hash.Add( player.Kills );
                    hash.Add( player.Deaths );
                    hash.Add( (int)GetPlayerAdminRole( player ) );
                }
                break;

            case ScoreboardPage.Jobs:
                hash.Add( LocalPlayer?.JobDefinitionPath );

                foreach ( var job in JobDefinitions )
                {
                    hash.Add( job.ResourcePath );
                    hash.Add( job.GetDisplayColor() );
                    hash.Add( JobManager.CountPlayers( job ) );
                }
                break;

            case ScoreboardPage.Shop:
                hash.Add( _selectedShopSection );
                hash.Add( LocalPlayerMoney );
                hash.Add( LocalPlayer?.JobDefinitionPath );
                hash.Add( LocalOwnedPrinterCount );
                hash.Add( TipJar.CountOwned( Connection.Local ) );
                hash.Add( Lawboard.CountOwned( Connection.Local ) );
                hash.Add( PrinterDefinitions.Count );

                foreach ( var definition in PrinterDefinitions )
                    hash.Add( definition.ResourcePath );

                foreach ( var definition in AmmoShopCatalog.GetAll() )
                    hash.Add( definition.PrefabPath );
                break;

            case ScoreboardPage.Administration:
                hash.Add( (int)LocalPlayerAdminRole );
                hash.Add( _adminSteamIdValue );

                foreach ( var staff in GetOnlineStaff() )
                {
                    hash.Add( staff.PlayerId );
                    hash.Add( (int)GetPlayerAdminRole( staff ) );
                }

                foreach ( var entry in GetSavedStaffEntries() )
                {
                    hash.Add( entry.Key.Value );
                    hash.Add( entry.Value.DisplayName );
                    hash.Add( (int)entry.Value.Role );
                }
                break;
        }

        return hash.ToHashCode();
    }
}
